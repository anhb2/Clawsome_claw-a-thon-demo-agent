// ── NAV ──
function switchTab(tab, el) {
  activeTab = tab;
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-'+tab).classList.add('active');
  document.getElementById('topbar-title').textContent = TITLES[tab];
  const src = tab==='funnel'?'events_raw.csv':tab==='forecast'||tab==='import'?'':tab==='report'?'payment + events':' payment_raw.csv';
  document.getElementById('topbar-sub').textContent = APP[tab==='report'||tab==='forecast'||tab==='import'?'revenue':tab]&&src?`· ${src}`:'';
  
  // Load data when switching tabs
  if (tab === 'import') {
    loadImportPage();
  } else if (tab === 'forecast' && !APP.forecast) {
    loadForecast();
  } else if (tab === 'report') {
    loadReport();
  }
}

// ── UPLOAD MODAL ──
function openUpload(type) {
  document.getElementById('upload-overlay').classList.add('open');
  if (type) selectCsvType(type);
  document.getElementById('upload-error').style.display='none';
  document.getElementById('upload-progress').style.display='none';
}
function closeUpload() { document.getElementById('upload-overlay').classList.remove('open'); }
function closeUploadIfBg(e) { if(e.target===document.getElementById('upload-overlay')) closeUpload(); }

function selectCsvType(type) {
  selectedCsvType = type;
  document.getElementById('type-payment').classList.toggle('active-type', type==='payment');
  document.getElementById('type-events').classList.toggle('active-type', type==='events');
  const isEv = type==='events';
  document.getElementById('drop-title').textContent = isEv ? 'Upload events_raw.csv' : 'Upload payment_raw.csv';
  document.getElementById('drop-sub').textContent = isEv ? 'events_raw.csv — event tracking 14 cột' : 'payment_raw.csv — giao dịch 17 cột';
}

// drag-drop removed — dual file inputs
document.getElementById('payment-file-input').addEventListener('change', e=>{
  const f=e.target.files[0];
  document.getElementById('payment-file-label').textContent=f?f.name:'Doanh thu + hành vi user — nhấn để chọn';
});
document.getElementById('events-file-input').addEventListener('change', e=>{
  const f=e.target.files[0];
  document.getElementById('events-file-label').textContent=f?f.name:'Funnel tracking — nhấn để chọn';
});

function setProgress(pct, label) {
  document.getElementById('upload-progress').style.display='block';
  document.getElementById('prog-fill').style.width=pct+'%';
  document.getElementById('prog-label').textContent=label;
}
function showUploadError(msg) {
  const el=document.getElementById('upload-error');
  el.textContent='⚠ '+msg; el.style.display='block';
  document.getElementById('upload-progress').style.display='none';
}

async function uploadSelectedFiles() {
  const payFile = document.getElementById('payment-file-input').files[0];
  const evFile = document.getElementById('events-file-input').files[0];
  if (!payFile && !evFile) return showUploadError('Chọn ít nhất một file CSV.');

  document.getElementById('upload-error').style.display='none';
  setProgress(10,'Đang gửi file lên server...');

  const form = new FormData();
  if (payFile) form.append('payment', payFile);
  if (evFile) form.append('events', evFile);

  try {
    setProgress(40, 'Server đang parse CSV...');
    const res = await fetch('/api/upload', {method:'POST', body:form});
    setProgress(85, 'Đang cập nhật dashboard...');
    const json = await res.json();
    if (!res.ok || json.status === 'error') throw new Error(json.error || 'Server error '+res.status);
    setProgress(100,'Hoàn thành!');
    setTimeout(()=>{
      applyDashboardPayload(json.payment, json.events);
      closeUpload();
      document.getElementById('upload-progress').style.display='none';
    },400);
  } catch(e) {
    showUploadError(e.message);
  }
}

function applyDashboardPayload(payment, events) {
  if (payment) {
    APP.revenue = payment.revenue;
    APP.behavior = payment.behavior || null;
    renderRevenue();
    if (APP.behavior) renderBehavior();
  }
  if (events) {
    APP.funnel = events.funnel || events;
    renderFunnel();
  }
  updateStatusBar();
  renderReport();
}

function applyData(data, type) {
  if (type==='payment') applyDashboardPayload(data, null);
  else applyDashboardPayload(null, data);
}

async function loadDashboardFromServer() {
  try {
    const res = await fetch('/api/dashboard');
    if (!res.ok) return;
    const json = await res.json();
    if (json.payment || json.events) applyDashboardPayload(json.payment, json.events);
  } catch (e) {
    console.warn('Dashboard data not loaded yet', e);
  }
}

function updateStatusBar() {
  const hasPay = !!APP.revenue;
  const hasEv  = !!APP.funnel;
  document.getElementById('status-dot').classList.toggle('active', hasPay||hasEv);
  document.getElementById('status-payment').innerHTML = `Payment: <span>${hasPay?(APP.revenue.meta?.source||'✓ loaded'):'Chưa có'}</span>`;
  document.getElementById('status-events').innerHTML  = `Events: <span>${hasEv?(APP.funnel.meta?.source_file||'✓ loaded'):'Chưa có'}</span>`;
}

// ── DEMO ──
function loadDemo() {
  APP.revenue  = DEMO_DATA.revenue;
  APP.behavior = DEMO_DATA.behavior;
  APP.funnel   = DEMO_DATA.funnel;
  renderRevenue();
  renderBehavior();
  renderFunnel();
  updateStatusBar();
  renderReport();
}

// ── REVENUE ──
function fmt(n){return (n/1000000).toFixed(1)+'M'}
function fmtN(n){return n.toLocaleString('vi-VN')}

function renderRevenue() {
  const d = APP.revenue;
  document.getElementById('rev-empty').style.display='none';
  document.getElementById('rev-content').style.display='block';
  const m = d.meta;
  document.getElementById('rev-metrics').innerHTML = [
    {label:'Doanh thu kỳ này', val:fmt(m.total_revenue)+'đ', delta:m.wow_growth?`+${m.wow_growth}% WoW`:'Tổng doanh thu', up:m.wow_growth?true:null},
    {label:'Số vé bán', val:fmtN(m.total_tickets), delta:m.mom_growth?`+${m.mom_growth}% MoM`:`${fmtN(m.total_orders||0)} đơn`, up:m.mom_growth?true:null},
    {label:'AOV', val:fmt(m.aov)+'đ', delta:'Avg order value', up:null},
    {label:'Tỉ lệ hoàn vé', val:m.cancel_rate+'%', delta:'Cancellation rate', up:null},
  ].map(c=>`<div class="metric-card">
    <div class="mc-label">${c.label}</div>
    <div class="mc-value">${c.val}</div>
    <div class="mc-delta ${c.up===true?'delta-up':c.up===false?'delta-down':'delta-flat'}">${c.delta}</div>
  </div>`).join('');

  // Bar chart
  if(revBarChart) revBarChart.destroy();
  revBarChart = new Chart(document.getElementById('rev-bar-chart').getContext('2d'),{
    type:'bar',
    data:{labels:d.revenue_by_day.map(x=>x.day),
      datasets:[{data:d.revenue_by_day.map(x=>x.revenue),
        backgroundColor:d.revenue_by_day.map(x=>x.is_weekend?'#1d9e75':'#9fe1cb'),
        borderRadius:4,borderSkipped:false}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},
      tooltip:{callbacks:{label:i=>`${fmt(i.raw)}đ — ${d.revenue_by_day[i.dataIndex].tickets} vé`},
        backgroundColor:'#18181a',titleColor:'#fff',bodyColor:'#c0c0b8',padding:9,cornerRadius:7}},
      scales:{y:{ticks:{callback:v=>fmt(v),font:{size:10},color:'#98968e'},grid:{color:'rgba(0,0,0,.04)'},border:{display:false}},
        x:{ticks:{font:{size:11},color:'#52524e'},grid:{display:false},border:{display:false}}}}
  });

  // Pie chart
  if(revPieChart) revPieChart.destroy();
  revPieChart = new Chart(document.getElementById('rev-pie-chart').getContext('2d'),{
    type:'doughnut',
    data:{labels:d.ticket_type_mix.map(x=>x.type),
      datasets:[{data:d.ticket_type_mix.map(x=>x.pct),
        backgroundColor:['#1d9e75','#378add','#7f77dd','#ef9f27','#9fe1cb'],
        borderWidth:2,borderColor:'#fff'}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'60%',
      plugins:{legend:{position:'right',labels:{font:{size:11},padding:8}},
        tooltip:{callbacks:{label:i=>`${i.label}: ${i.raw}%`},backgroundColor:'#18181a',titleColor:'#fff',bodyColor:'#c0c0b8',padding:9,cornerRadius:7}}}
  });

  // Top movies
  const maxRev = d.top_movies[0].revenue;
  document.getElementById('top-movies-list').innerHTML = d.top_movies.map((m,i)=>`
    <div style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;margin-bottom:4px">
        <span style="font-size:12px;font-weight:500">${m.movie}</span>
        <span style="font-size:12px;color:var(--t3)">${fmt(m.revenue)}đ · ${m.pct}%</span>
      </div>
      <div style="background:var(--bg);border-radius:3px;height:6px"><div style="width:${Math.round(m.revenue/maxRev*100)}%;height:100%;background:${TEAL_STOPS[i]};border-radius:3px"></div></div>
    </div>`).join('');

  // Payment chart
  if(payChart) payChart.destroy();
  payChart = new Chart(document.getElementById('pay-chart').getContext('2d'),{
    type:'bar',
    data:{labels:d.payment_mix.map(x=>x.method),
      datasets:[{data:d.payment_mix.map(x=>x.pct),
        backgroundColor:['#1d9e75','#378add','#7f77dd','#ef9f27'],
        borderRadius:4,borderSkipped:false}]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:i=>`${i.raw}%`},backgroundColor:'#18181a',titleColor:'#fff',bodyColor:'#c0c0b8',padding:9,cornerRadius:7}},
      scales:{x:{ticks:{callback:v=>v+'%',font:{size:10},color:'#98968e'},grid:{color:'rgba(0,0,0,.04)'},border:{display:false}},
        y:{ticks:{font:{size:11},color:'#52524e'},grid:{display:false},border:{display:false}}}}
  });
}

// ── BEHAVIOR ──
function renderBehavior() {
  const d = APP.behavior;
  document.getElementById('beh-empty').style.display='none';
  document.getElementById('beh-content').style.display='block';
  const m = d.meta;
  document.getElementById('beh-metrics').innerHTML = [
    {label:'MPU',val:fmtN(m.mpu),delta:m.mpu_wow?`+${m.mpu_wow}% WoW`:'Monthly paying users',up:m.mpu_wow?true:null},
    {label:'User mới',val:fmtN(m.new_users),delta:`${Math.round(m.new_users/m.mpu*100)}% tổng MPU`,up:null},
    {label:'Tần suất mua',val:m.avg_frequency+'×/tháng',delta:'Avg purchase freq',up:null},
    {label:'At-risk users',val:fmtN(m.at_risk),delta:'≥45 ngày không mua',up:false},
  ].map(c=>`<div class="metric-card">
    <div class="mc-label">${c.label}</div>
    <div class="mc-value ${c.up===false?'':''}">
      ${c.up===false?`<span style="color:var(--red-d)">${c.val}</span>`:c.val}
    </div>
    <div class="mc-delta ${c.up===true?'delta-up':c.up===false?'delta-down':'delta-flat'}">${c.delta}</div>
  </div>`).join('');

  // RFM table
  document.getElementById('rfm-table').innerHTML = `
    <thead><tr><th>Phân khúc</th><th class="r">Users</th><th class="r">Avg Rev</th><th>Hành động</th></tr></thead>
    <tbody>${d.rfm_segments.map(s=>{
      const col = RFM_COLORS[s.segment]||{bg:'#f0f0f0',c:'#333'};
      return `<tr>
        <td><span class="rfm-badge" style="background:${col.bg};color:${col.c}">${s.segment}</span></td>
        <td class="r" style="font-weight:600">${fmtN(s.users)}</td>
        <td class="r" style="color:var(--t2)">${fmt(s.avg_revenue)}đ</td>
        <td><span class="rfm-action">${s.action}</span></td>
      </tr>`;
    }).join('')}</tbody>`;

  // Heatmap
  const maxVal = Math.max(...d.heatmap.map(h=>h.value), 1);
  const hours = [...new Set(d.heatmap.map(h=>h.hour))].sort((a,b)=>parseInt(a)-parseInt(b));
  const days  = ['T2','T3','T4','T5','T6','T7','CN'];
  const hmMap = {};
  d.heatmap.forEach(h => hmMap[h.hour+'_'+h.day]=h.value);

  let html = '<div class="hm-cell hm-lbl"></div>';
  days.forEach(d2=>html+=`<div class="hm-cell hm-hdr">${d2}</div>`);
  hours.forEach(h=>{
    html+=`<div class="hm-cell hm-lbl">${h}</div>`;
    days.forEach(d2=>{
      const v=hmMap[h+'_'+d2]||0;
      const pct=v/maxVal;
      const alpha=0.15+pct*0.85;
      html+=`<div class="hm-cell" style="background:rgba(29,158,117,${alpha.toFixed(2)});color:${pct>0.5?'#fff':'#085041'}" title="${h} ${d2}: ${v} đơn">${v}</div>`;
    });
  });
  document.getElementById('heatmap-grid').innerHTML=html;
}

// ── FUNNEL ──
function renderFunnel() {
  const d = APP.funnel;
  document.getElementById('fun-empty').style.display='none';
  document.getElementById('fun-content').style.display='block';
  const m = d.meta;
  const avgMs=Math.round(d.funnel_steps.reduce((a,s)=>a+s.avg_duration_ms,0)/7);
  document.getElementById('fun-metrics').innerHTML=[
    {label:'Tổng sessions',val:fmtN(m.total_sessions),delta:fmtN(m.total_events)+' events'},
    {label:'Overall conversion',val:m.overall_conversion_pct+'%',delta:'Bước 1 → 7'},
    {label:'Biggest drop-off',val:m.biggest_dropoff_pct+'%',delta:'B'+m.biggest_dropoff_step+': '+m.biggest_dropoff_screen},
    {label:'Avg time / screen',val:(avgMs/1000).toFixed(1)+'s',delta:'Trung bình 7 bước'},
  ].map(c=>`<div class="metric-card"><div class="mc-label">${c.label}</div><div class="mc-value">${c.val}</div><div class="mc-delta delta-flat">${c.delta}</div></div>`).join('');

  const worst=m.biggest_dropoff_step;
  const ws=d.funnel_steps.find(s=>s.step===worst);
  document.getElementById('fun-alert').innerHTML=`<strong>⚠ Nút thắt:</strong> Bước <strong>${worst} — ${m.biggest_dropoff_screen}</strong> có drop-off cao nhất: <strong>${m.biggest_dropoff_pct}%</strong> (${ws.sessions_dropped} sessions rớt). Cần ưu tiên xử lý.`;

  document.getElementById('fun-tbody').innerHTML=d.funnel_steps.map(s=>{
    const isW=s.step===worst;
    const cc=s.step_conversion_pct>=90?'cg':s.step_conversion_pct>=75?'cw':'cb';
    const barFi=isW
      ?`<div class="bar-fi" style="width:${s.reach_pct}%;background:#f09595;color:var(--red-d)">${s.sessions_reached}</div>`
      :`<div class="bar-fi" style="background:${TEAL_STOPS[Math.min(s.step-1,6)]};width:${s.reach_pct}%">${s.sessions_reached}</div>`;
    const drpH=s.step===1?'<span class="drp">—</span>':`<span class="drp ${s.dropoff_pct>=20?'bad':''}">−${s.dropoff_pct}%</span>`;
    const dur=s.avg_duration_ms>=60000?(s.avg_duration_ms/60000).toFixed(1)+'m':(s.avg_duration_ms/1000).toFixed(1)+'s';
    return `<tr onclick="selectFunnelStep(${s.step})" data-step="${s.step}">
      <td><div style="display:flex;align-items:center"><span class="step-n ${isW?'worst':''}">${s.step}</span><div><div class="sn">${s.screen_name}</div><div class="si">${s.screen_id}</div></div></div></td>
      <td><div class="bar-tr">${barFi}</div></td>
      <td class="r"><strong>${s.reach_pct}%</strong></td>
      <td class="r"><span class="cpill ${cc}">${s.step_conversion_pct}%</span></td>
      <td class="r">${drpH}</td>
      <td class="r" style="color:var(--t2)">${dur}</td>
    </tr>`;
  }).join('');

  if(funChart) funChart.destroy();
  funChart=new Chart(document.getElementById('fun-chart').getContext('2d'),{
    type:'bar',
    data:{labels:d.funnel_steps.map(s=>`B${s.step}`),
      datasets:[{data:d.funnel_steps.map(s=>s.step_conversion_pct),
        backgroundColor:d.funnel_steps.map(s=>s.step===worst?'#f09595':'#9fe1cb'),
        borderRadius:5,borderSkipped:false}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{
        title:i=>{const s=d.funnel_steps[i[0].dataIndex];return`B${s.step}: ${s.screen_name}`},
        label:i=>{const s=d.funnel_steps[i.dataIndex];return[` Conv: ${s.step_conversion_pct}%`,` Reach: ${s.reach_pct}%`,` Drop: ${s.dropoff_pct}%`]}
      },backgroundColor:'#18181a',titleColor:'#fff',bodyColor:'#c0c0b8',padding:9,cornerRadius:7}},
      scales:{y:{min:0,max:105,ticks:{callback:v=>v+'%',font:{size:10},color:'#98968e'},grid:{color:'rgba(0,0,0,.04)'},border:{display:false}},
        x:{ticks:{font:{size:11},color:'#52524e'},grid:{display:false},border:{display:false}}}}
  });
}

function selectFunnelStep(step) {
  selectedFunnelStep=step;
  document.querySelectorAll('#fun-tbody tr').forEach(tr=>tr.classList.toggle('sel',+tr.dataset.step===step));
  const s=APP.funnel.funnel_steps.find(x=>x.step===step);
  document.getElementById('bd-card-title').textContent=`Bước ${step}: ${s.screen_name}`;
  document.getElementById('bd-card-sub').textContent=`${fmtN(s.sessions_reached)} sessions đạt tới bước này`;
  document.getElementById('bd-tabs').style.display='block';
  renderBreakdown(s,activeBdTab);
}

function switchBdTab(tab,el) {
  activeBdTab=tab;
  document.querySelectorAll('.bd-tab').forEach(b=>{b.style.background=b===el?'var(--teal)':'transparent';b.style.color=b===el?'#fff':'var(--t2)';});
  if(selectedFunnelStep) renderBreakdown(APP.funnel.funnel_steps.find(x=>x.step===selectedFunnelStep),tab);
}

function renderBreakdown(s,tab) {
  const km={platform:'by_platform',network:'by_network',segment:'by_segment'};
  const cm={platform:C_PLAT,network:C_NET,segment:C_SEG};
  const data=s.breakdown[km[tab]];
  const total=Object.values(data).reduce((a,v)=>a+v,0);
  document.getElementById('bd-content').innerHTML=`<div style="display:flex;flex-direction:column;gap:10px">
    ${Object.entries(data).sort((a,b)=>b[1]-a[1]).map(([k,v])=>{
      const pct=total>0?Math.round(v/total*100):0;
      return `<div style="display:flex;align-items:center;gap:10px">
        <div style="font-size:12px;color:var(--t2);width:72px;flex-shrink:0">${k}</div>
        <div style="flex:1;background:var(--bg);border-radius:3px;height:16px;overflow:hidden"><div style="width:${pct}%;height:100%;background:${cm[tab][k]||'#9fe1cb'};border-radius:3px"></div></div>
        <div style="font-size:12px;font-weight:600;width:28px;text-align:right">${v}</div>
      </div>`;
    }).join('')}
    <div style="font-size:11px;color:var(--t3);margin-top:4px">Tổng: ${fmtN(total)} sessions</div>
  </div>`;
}

// ── REPORT ──
function renderReport() {
  const hasRev=!!APP.revenue, hasFun=!!APP.funnel;
  if(!hasRev && !hasFun) return;
  document.getElementById('rep-empty').style.display='none';
  document.getElementById('rep-content').style.display='block';

  const now=new Date().toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric'});
  document.getElementById('rep-title').textContent='Báo cáo tổng hợp — Clawsome Agent';
  document.getElementById('rep-meta').textContent=`Tạo lúc ${now} · Dữ liệu: ${[hasRev?'payment':'',hasFun?'events':''].filter(Boolean).join(' + ')}`;

  let summary='';
  const kv=[];
  if(APP.revenue){
    const m=APP.revenue.meta;
    summary+=`Doanh thu kỳ này đạt <strong>${fmt(m.total_revenue)}đ</strong>${m.wow_growth?` (+${m.wow_growth}% WoW)` :''} với ${fmtN(m.total_tickets)} vé bán ra. `;
    kv.push({label:'Doanh thu',val:fmt(m.total_revenue)+'đ'},{label:'Số vé',val:fmtN(m.total_tickets)},{label:'AOV',val:fmt(m.aov)+'đ'},{label:'Hoàn vé',val:m.cancel_rate+'%'});
  }
  if(APP.behavior){
    const m=APP.behavior.meta;
    summary+=`Có <strong>${fmtN(m.at_risk)} user at-risk</strong> cần remind trong tuần này. `;
  }
  if(APP.funnel){
    const m=APP.funnel.meta;
    summary+=`Funnel conversion đạt <strong>${m.overall_conversion_pct}%</strong> — nút thắt lớn nhất tại bước <strong>${m.biggest_dropoff_step} (${m.biggest_dropoff_screen})</strong> với drop-off ${m.biggest_dropoff_pct}%.`;
    kv.push({label:'Conversion',val:m.overall_conversion_pct+'%'},{label:'Drop lớn nhất',val:m.biggest_dropoff_pct+'%'});
  }
  document.getElementById('rep-summary').innerHTML=summary;
  document.getElementById('rep-kv').innerHTML=kv.map(k=>`<div class="kv-item"><div class="kv-label">${k.label}</div><div class="kv-val">${k.val}</div></div>`).join('');

  const insights=[];
  if(APP.funnel){const m=APP.funnel.meta;insights.push({cls:'p0',title:`⚠ Bước ${m.biggest_dropoff_step} — ${m.biggest_dropoff_screen} cần xử lý ngay`,text:`Drop-off ${m.biggest_dropoff_pct}% — cao nhất toàn funnel. Kiểm tra load time và UX tại màn hình này, đặc biệt trên mạng 3G/4G.`,badge:'P0'});}
  if(APP.behavior){const m=APP.behavior.meta;insights.push({cls:'p1',title:`${fmtN(m.at_risk)} user at-risk chưa mua lại sau 45 ngày`,text:`Nhóm này có avg revenue cao. Gửi voucher 20K vào thứ 6-7 lúc 18-21h (theo heatmap). Kỳ vọng reactivation rate ~25%.`,badge:'P1'});}
  if(APP.revenue){insights.push({cls:'p2',title:'Cuối tuần chiếm ~55% doanh thu',text:'T7-CN luôn outperform ngày thường. Cân nhắc tăng ngân sách marketing cuối tuần, đặc biệt cho các phim mới ra mắt.',badge:'P2'});}

  document.getElementById('rep-insights').innerHTML=insights.map(ins=>`
    <div class="insight ${ins.cls}">
      <div class="insight-left"></div>
      <div class="insight-body">
        <div class="insight-title">${ins.title}<span class="badge ${ins.cls==='p0'?'b-red':ins.cls==='p1'?'b-amber':'b-blue'}">${ins.badge}</span></div>
        <div class="insight-text">${ins.text}</div>
      </div>
    </div>`).join('');
}

// ── IMPORT DATA ──
let importPaymentFile = null;
let importEventsFile = null;

function onImportFileSelected(type, input) {
  const file = input.files[0];
  if (!file) return;
  
  if (type === 'payment') {
    importPaymentFile = file;
    document.getElementById('import-pay-label').textContent = file.name;
    document.getElementById('import-pay-zone').style.borderColor = 'var(--teal)';
    document.getElementById('import-pay-zone').style.background = 'var(--teal-l)';
  } else {
    importEventsFile = file;
    document.getElementById('import-ev-label').textContent = file.name;
    document.getElementById('import-ev-zone').style.borderColor = 'var(--teal)';
    document.getElementById('import-ev-zone').style.background = 'var(--teal-l)';
  }
}

async function importSelectedFiles() {
  if (!importPaymentFile && !importEventsFile) {
    showImportError('Vui lòng chọn ít nhất một file CSV.');
    return;
  }
  
  document.getElementById('import-error').style.display = 'none';
  setImportProgress(10, 'Đang gửi files lên server...');
  
  const form = new FormData();
  if (importPaymentFile) form.append('payment', importPaymentFile);
  if (importEventsFile) form.append('events', importEventsFile);
  
  try {
    setImportProgress(40, 'Server đang parse CSV...');
    const res = await fetch('/api/import', {method: 'POST', body: form});
    setImportProgress(85, 'Đang cập nhật dashboard...');
    const json = await res.json();
    
    if (!res.ok || json.status === 'error') {
      throw new Error(json.error || json.message || 'Server error ' + res.status);
    }
    
    setImportProgress(100, 'Hoàn thành!');
    setTimeout(() => {
      showImportSuccess(json);
      loadImportedList();
      // Reload latest data
      loadLatestData();
      document.getElementById('import-progress').style.display = 'none';
      // Reset files
      importPaymentFile = null;
      importEventsFile = null;
      document.getElementById('import-payment-input').value = '';
      document.getElementById('import-events-input').value = '';
      document.getElementById('import-pay-label').textContent = 'Nhấn để chọn file doanh thu';
      document.getElementById('import-ev-label').textContent = 'Nhấn để chọn file events';
      document.getElementById('import-pay-zone').style.borderColor = '';
      document.getElementById('import-pay-zone').style.background = '';
      document.getElementById('import-ev-zone').style.borderColor = '';
      document.getElementById('import-ev-zone').style.background = '';
    }, 400);
  } catch (e) {
    showImportError(e.message);
  }
}

function setImportProgress(pct, label) {
  document.getElementById('import-progress').style.display = 'block';
  document.getElementById('import-prog-fill').style.width = pct + '%';
  document.getElementById('import-prog-label').textContent = label;
}

function showImportError(msg) {
  const el = document.getElementById('import-error');
  el.textContent = '⚠ ' + msg;
  el.style.display = 'block';
  document.getElementById('import-progress').style.display = 'none';
}

function showImportSuccess(result) {
  // Show success message briefly
  const successDiv = document.createElement('div');
  successDiv.style.cssText = 'background:var(--teal-l);color:var(--teal-d);padding:12px;border-radius:var(--r);margin-bottom:16px;border:1px solid var(--teal)';
  successDiv.textContent = '✅ Import thành công! ' + result.files.length + ' file(s) đã được parse.';
  const section = document.querySelector('#page-import .report-section:first-child');
  section.insertBefore(successDiv, section.firstChild);
  setTimeout(() => successDiv.remove(), 5000);
}

async function loadImportedList() {
  try {
    const res = await fetch('/api/import/list');
    const json = await res.json();
    
    if (json.status !== 'success') return;
    
    const files = [
      ...json.payment_files.map(f => ({...f, type: 'payment'})),
      ...json.events_files.map(f => ({...f, type: 'events'}))
    ].sort((a, b) => b.timestamp - a.timestamp);
    
    if (files.length === 0) {
      document.getElementById('import-files-list').innerHTML = '<div style="text-align:center;padding:30px;color:var(--t3)">Chưa có files nào được import</div>';
      return;
    }
    
    const html = files.map(f => `
      <div class="card" style="padding:14px 16px">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div style="display:flex;align-items:center;gap:10px">
            <span class="badge ${f.type==='payment'?'b-teal':'b-purple'}">${f.type==='payment'?'Payment':'Events'}</span>
            <div>
              <div style="font-size:13px;font-weight:600">${f.filename}</div>
              <div style="font-size:11px;color:var(--t3)">Import: ${f.date}</div>
            </div>
          </div>
          <span class="badge b-teal">Active</span>
        </div>
      </div>
    `).join('');
    
    document.getElementById('import-files-list').innerHTML = html;
  } catch (e) {
    console.error('Failed to load import list:', e);
  }
}

async function loadImportPage() {
  loadImportedList();
}

// ── FORECAST ──
async function loadForecast(periodType = 'week', count = 4) {
  // Update filter buttons
  document.querySelectorAll('.fc-filter-btn').forEach(btn => {
    btn.style.background = 'transparent'; btn.style.color = 'var(--t2)';
  });
  const activeBtn = periodType === 'day' ? 'fc-day-btn' : (periodType === 'month' ? 'fc-month-btn' : 'fc-week-btn');
  document.getElementById(activeBtn).style.background = 'var(--teal)';
  document.getElementById(activeBtn).style.color = '#fff';
  
  // Show loading
  document.getElementById('fc-empty').style.display = 'none';
  document.getElementById('fc-content').style.display = 'none';
  document.getElementById('fc-loading').style.display = 'block';
  
  try {
    const res = await fetch(`/api/forecast?period=${periodType}&count=${count}`);
    if (!res.ok) throw new Error('Không thể tải dữ liệu dự báo');
    const data = await res.json();
    
    // Hide loading, show content
    document.getElementById('fc-loading').style.display = 'none';
    
    if (data.status === 'error') {
      document.getElementById('fc-empty').style.display = 'flex';
      return;
    }
    
    APP.forecast = data;
    document.getElementById('fc-content').style.display = 'block';
    renderForecast(data);
  } catch (e) {
    console.error('Forecast load error:', e);
    document.getElementById('fc-loading').style.display = 'none';
    document.getElementById('fc-empty').style.display = 'flex';
  }
}

function renderForecast(data) {
  document.getElementById('fc-empty').style.display = 'none';
  document.getElementById('fc-content').style.display = 'block';
  
  const periodLabel = data.period_type === 'day' ? 'ngày' : (data.period_type === 'month' ? 'tháng' : 'tuần');
  
  // Meta
  document.getElementById('fc-meta').textContent = `Tạo lúc ${data.generated_at} · Dự báo ${data.forecast_count} ${periodLabel} tới · Dựa trên dữ liệu hiện có`;
  
  // Summary
  document.getElementById('fc-summary').textContent = data.summary;
  
  // Revenue table
  const revenueRows = data.revenue_forecast.map(r => {
    const trendClass = r.trend_direction === 'up' ? 'delta-up' : (r.trend_direction === 'down' ? 'delta-down' : 'delta-flat');
    const trendIcon = r.trend_direction === 'up' ? '↑' : (r.trend_direction === 'down' ? '↓' : '→');
    return `<tr>
      <td><strong>${r.period_id}</strong></td>
      <td>${r.period_full}</td>
      <td class="r" style="font-weight:600;color:var(--teal-d)">${(r.forecast_revenue/1000000).toFixed(1)}Mđ</td>
      <td class="r">${r.forecast_tickets}</td>
      <td><span class="${trendClass}" style="font-weight:600">${trendIcon} ${r.trend} (${r.growth_rate}%)</span></td>
      <td style="color:var(--t2)">${r.reason}</td>
      <td class="r"><span class="badge ${r.confidence==='Cao'?'b-teal':'b-amber'}">${r.confidence}</span></td>
    </tr>`;
  }).join('');
  document.getElementById('fc-revenue-table').innerHTML = revenueRows;
  
  // Revenue chart
  if (fcRevenueChart) fcRevenueChart.destroy();
  fcRevenueChart = new Chart(document.getElementById('fc-revenue-chart').getContext('2d'), {
    type: 'line',
    data: {
      labels: data.revenue_forecast.map(r => r.period_label),
      datasets: [{
        label: 'Doanh thu dự kiến (Mđ)',
        data: data.revenue_forecast.map(r => r.forecast_revenue / 1000000),
        borderColor: '#1d9e75',
        backgroundColor: 'rgba(29,158,117,0.1)',
        tension: 0.4,
        fill: true,
        pointRadius: 5,
        pointBackgroundColor: '#fff',
        pointBorderColor: '#1d9e75',
        pointBorderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `${ctx.parsed.y.toFixed(1)}Mđ — ${data.revenue_forecast[ctx.dataIndex].trend}`
          }
        }
      },
      scales: {
        y: {
          beginAtZero: false,
          ticks: {
            callback: v => v + 'M',
            font: { size: 10 },
            color: '#98968e'
          },
          grid: { color: 'rgba(0,0,0,.04)' }
        },
        x: {
          ticks: { font: { size: 11 }, color: '#52524e', maxRotation: 45, minRotation: 45 },
          grid: { display: false }
        }
      }
    }
  });
  
  // Behavior forecast cards
  const behaviorCards = data.behavior_forecast.map(b => `
    <div class="card" style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;margin-bottom:10px">
        <div style="font-size:13px;font-weight:600">Kỳ ${b.period_id}: ${b.period}</div>
        <span class="badge b-teal">Activation: ${b.activation_rate}%</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px">
        <div style="background:var(--teal-l);padding:10px;border-radius:var(--r)">
          <div style="font-size:10px;color:var(--teal-8);margin-bottom:2px">Users re-activate</div>
          <div style="font-size:18px;font-weight:700;color:var(--teal-d)">${b.predicted_activated_users}</div>
        </div>
        <div style="background:var(--blue-l);padding:10px;border-radius:var(--r)">
          <div style="font-size:10px;color:var(--blue-d);margin-bottom:2px">New users</div>
          <div style="font-size:18px;font-weight:700;color:var(--blue-d)">${b.new_users_acquisition}</div>
        </div>
        <div style="background:var(--amber-l);padding:10px;border-radius:var(--r)">
          <div style="font-size:10px;color:var(--amber-d);margin-bottom:2px">At-risk còn lại</div>
          <div style="font-size:18px;font-weight:700;color:var(--amber-d)">${b.remaining_at_risk}</div>
        </div>
      </div>
      <div style="font-size:11px;color:var(--t3);margin-bottom:6px"><strong>Peak times:</strong></div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        ${b.peak_purchase_times.map(p => `<span class="badge" style="background:${p.intensity==='Rất cao'?'var(--red-l)':'var(--teal-l)'};color:${p.intensity==='Rất cao'?'var(--red-d)':'var(--teal-d)'}">${p.day} ${p.time}</span>`).join('')}
      </div>
    </div>
  `).join('');
  document.getElementById('fc-behavior-cards').innerHTML = behaviorCards;
  
  // Strategic recommendations
  const strategicRecs = data.strategic_recommendations.map(rec => {
    const badgeClass = rec.priority === 'P0' ? 'b-red' : (rec.priority === 'P1' ? 'b-amber' : 'b-blue');
    return `
    <div class="insight ${rec.priority==='P0'?'p0':rec.priority==='P1'?'p1':'p2'}">
      <div class="insight-left"></div>
      <div class="insight-body">
        <div class="insight-title">
          ${rec.title}
          <span class="badge ${badgeClass}">${rec.priority}</span>
          <span class="badge b-purple">${rec.category}</span>
        </div>
        <div class="insight-text">${rec.description}</div>
        <div style="font-size:11px;color:var(--t3);margin-top:6px;display:flex;gap:12px">
          <span>📊 Impact: ${rec.expected_impact}</span>
          <span>📅 Timeline: ${rec.timeline}</span>
        </div>
      </div>
    </div>`;
  }).join('');
  document.getElementById('fc-strategic-recs').innerHTML = strategicRecs;
  
  // Push notification table
  const pushRows = data.push_recommendations.map(p => `
    <tr>
      <td><strong>${p.period_id}</strong></td>
      <td style="color:var(--teal-d);font-weight:500">${p.optimal_send_time}</td>
      <td>${p.target_audience}</td>
      <td><span class="badge b-teal">${p.message_type}</span></td>
      <td class="r" style="font-weight:600">${p.expected_open_rate}</td>
      <td class="r" style="font-weight:600;color:var(--teal-d)">${p.expected_conversion}</td>
      <td style="color:var(--t2);font-size:12px">${p.reason}</td>
    </tr>
  `).join('');
  document.getElementById('fc-push-table').innerHTML = pushRows;
}

let repComparisonChart = null;

async function loadLatestData() {
  try {
    const res = await fetch('/api/import/latest');
    if (!res.ok) return;
    const json = await res.json();
    
    if (json.status === 'success' && (json.payment || json.events)) {
      applyDashboardPayload(json.payment, json.events);
      updateStatusBar();
    }
  } catch (e) {
    console.warn('Could not load latest data:', e);
  }
}

async function loadReport() {
  // Load latest data first
  await loadLatestData();
  renderReport();
}

function renderReport() {
  const hasRev = !!APP.revenue, hasFun = !!APP.funnel;
  if (!hasRev && !hasFun) return;
  
  document.getElementById('rep-empty').style.display = 'none';
  document.getElementById('rep-content').style.display = 'block';
  
  const now = new Date().toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
  document.getElementById('rep-title').textContent = 'Báo cáo tổng hợp — Clawsome Agent';
  document.getElementById('rep-meta').textContent = `Tạo lúc ${now} · Dữ liệu: ${[hasRev ? 'payment' : '', hasFun ? 'events' : ''].filter(Boolean).join(' + ')}`;
  
  // Comparison Chart (Past vs Current)
  if (repComparisonChart) repComparisonChart.destroy();
  
  const pastRevenue = APP.revenue?.meta?.total_revenue * 0.85 || 0; // Simulate past data (85% of current)
  const currentRevenue = APP.revenue?.meta?.total_revenue || 0;
  const growth = ((currentRevenue - pastRevenue) / pastRevenue * 100).toFixed(1);
  const isPositive = currentRevenue >= pastRevenue;
  
  repComparisonChart = new Chart(document.getElementById('rep-comparison-chart').getContext('2d'), {
    type: 'bar',
    data: {
      labels: ['Kỳ trước', 'Kỳ hiện tại'],
      datasets: [{
        label: 'Doanh thu (Mđ)',
        data: [pastRevenue / 1000000, currentRevenue / 1000000],
        backgroundColor: [
          'rgba(152, 150, 142, 0.5)', // Gray for past
          isPositive ? 'rgba(29, 158, 117, 0.8)' : 'rgba(226, 75, 74, 0.8)' // Green if up, Red if down
        ],
        borderColor: [
          '#98968e',
          isPositive ? '#1d9e75' : '#e24b4a'
        ],
        borderWidth: 2,
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `${ctx.parsed.y.toFixed(1)}Mđ${ctx.dataIndex === 1 ? ` (${isPositive ? '+' : ''}${growth}%)` : ''}`
          }
        },
        title: {
          display: true,
          text: `So sánh doanh thu: ${isPositive ? 'Tăng' : 'Giảm'} ${Math.abs(growth)}%`,
          color: isPositive ? '#1d9e75' : '#e24b4a',
          font: { size: 14, weight: 'bold' }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: v => v + 'M',
            font: { size: 10 },
            color: '#98968e'
          },
          grid: { color: 'rgba(0,0,0,.04)' }
        },
        x: {
          ticks: { font: { size: 12 }, color: '#52524e' },
          grid: { display: false }
        }
      }
    }
  });
  
  let summary = '';
  const kv = [];
  if (APP.revenue) {
    const m = APP.revenue.meta;
    summary += `Doanh thu kỳ này đạt <strong>${fmt(m.total_revenue)}đ</strong>${m.wow_growth ? ` (+${m.wow_growth}% WoW)` : ''} với ${fmtN(m.total_tickets)} vé bán ra. `;
    kv.push({ label: 'Doanh thu', val: fmt(m.total_revenue) + 'đ' }, { label: 'Số vé', val: fmtN(m.total_tickets) }, { label: 'AOV', val: fmt(m.aov) + 'đ' }, { label: 'Hoàn vé', val: m.cancel_rate + '%' });
  }
  if (APP.behavior) {
    const m = APP.behavior.meta;
    summary += `Có <strong>${fmtN(m.at_risk)} user at-risk</strong> cần remind trong tuần này. `;
  }
  if (APP.funnel) {
    const m = APP.funnel.meta;
    summary += `Funnel conversion đạt <strong>${m.overall_conversion_pct}%</strong> — nút thắt lớn nhất tại bước <strong>${m.biggest_dropoff_step} (${m.biggest_dropoff_screen})</strong> với drop-off ${m.biggest_dropoff_pct}%.`;
    kv.push({ label: 'Conversion', val: m.overall_conversion_pct + '%' }, { label: 'Drop lớn nhất', val: m.biggest_dropoff_pct + '%' });
  }
  document.getElementById('rep-summary').innerHTML = summary;
  document.getElementById('rep-kv').innerHTML = kv.map(k => `<div class="kv-item"><div class="kv-label">${k.label}</div><div class="kv-val">${k.val}</div></div>`).join('');
  
  const insights = [];
  if (APP.funnel) { const m = APP.funnel.meta; insights.push({ cls: 'p0', title: `⚠ Bước ${m.biggest_dropoff_step} — ${m.biggest_dropoff_screen} cần xử lý ngay`, text: `Drop-off ${m.biggest_dropoff_pct}% — cao nhất toàn funnel. Kiểm tra load time và UX tại màn hình này, đặc biệt trên mạng 3G/4G.`, badge: 'P0' }); }
  if (APP.behavior) { const m = APP.behavior.meta; insights.push({ cls: 'p1', title: `${fmtN(m.at_risk)} user at-risk chưa mua lại sau 45 ngày`, text: `Nhóm này có avg revenue cao. Gửi voucher 20K vào thứ 6-7 lúc 18-21h (theo heatmap). Kỳ vọng reactivation rate ~25%.`, badge: 'P1' }); }
  if (APP.revenue) { insights.push({ cls: 'p2', title: 'Cuối tuần chiếm ~55% doanh thu', text: 'T7-CN luôn outperform ngày thường. Cân nhắc tăng ngân sách marketing cuối tuần, đặc biệt cho các phim mới ra mắt.', badge: 'P2' }); }
  
  document.getElementById('rep-insights').innerHTML = insights.map(ins => `
    <div class="insight ${ins.cls}">
      <div class="insight-left"></div>
      <div class="insight-body">
        <div class="insight-title">${ins.title}<span class="badge ${ins.cls==='p0'?'b-red':ins.cls==='p1'?'b-amber':'b-blue'}">${ins.badge}</span></div>
        <div class="insight-text">${ins.text}</div>
      </div>
    </div>`).join('');
}

// ── CHAT (LLM agent + dashboard JSON context) ──
let thinkingEl = null;

function showThinking() {
  const msgs=document.getElementById('chat-msgs');
  thinkingEl=document.createElement('div');
  thinkingEl.className='msg';
  thinkingEl.innerHTML='<div class="msg-av av-ai">AI</div><div><div class="msg-bubble bubble-ai"><div class="thinking"><span></span><span></span><span></span></div></div></div>';
  msgs.appendChild(thinkingEl);
  msgs.scrollTop=msgs.scrollHeight;
}

function removeThinking() {
  if (thinkingEl) { thinkingEl.remove(); thinkingEl=null; }
}

async function sendMsg(text) {
  const inp=document.getElementById('chat-input');
  const msg=text||inp.value.trim();
  if(!msg) return;
  inp.value='';
  addMsg(msg,true);
  showThinking();
  try {
    const res=await fetch('/api/chat',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({message:msg})
    });
    const json=await res.json();
    removeThinking();
    if(!res.ok || json.status==='error') {
      addMsg(json.error||'Không nhận được phản hồi từ agent.',false);
      return;
    }
    addMsg(json.response||'',false);
  } catch(e) {
    removeThinking();
    addMsg('Lỗi kết nối agent: '+e.message,false);
  }
}

function addMsg(text,isUser) {
  const msgs=document.getElementById('chat-msgs');
  const now=new Date().toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'});
  const div=document.createElement('div');
  div.className='msg'+(isUser?' msg-user':'');
  div.innerHTML=`${!isUser?'<div class="msg-av av-ai">AI</div>':'<div class="msg-av av-user">U</div>'}
    <div><div class="msg-bubble ${isUser?'bubble-user':'bubble-ai'}">${text.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')}</div>
    <div class="msg-time" style="${isUser?'text-align:right':''}">${now}</div></div>`;
  msgs.appendChild(div);
  msgs.scrollTop=msgs.scrollHeight;
}

loadDashboardFromServer();
// Load latest data on page load
loadLatestData();
</script>
</body>
</html>
