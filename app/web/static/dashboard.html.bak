<script>
// ── STATE ──
let APP = { revenue: null, behavior: null, funnel: null }, activeTab = 'revenue';
let revBarChart = null, revPieChart = null, payChart = null, funChart = null, fcRevenueChart = null;

const TITLES = {revenue:'Doanh thu',behavior:'Hành vi người dùng',funnel:'Funnel chuyển đổi',import:'Import CSV',report:'Báo cáo tổng hợp',forecast:'Dự báo AI'};

// Helper functions for Import tab - Multi-file upload
function updateImportFileLabel() {
  const input = document.getElementById('import-multi-input');
  const files = input.files;
  if (files.length === 0) {
    document.getElementById('import-drop-title').textContent = 'Nhấn để chọn file CSV';
    document.getElementById('import-drop-sub').textContent = 'Có thể chọn nhiều file cùng lúc';
  } else if (files.length === 1) {
    document.getElementById('import-drop-title').textContent = files[0].name;
    document.getElementById('import-drop-sub').textContent = 'Nhấn để thêm file khác hoặc thay đổi';
  } else {
    document.getElementById('import-drop-title').textContent = `${files.length} file đã chọn`;
    document.getElementById('import-drop-sub').textContent = Array.from(files).map(f => f.name).join(', ');
  }
}

function setImportProgress(pct, label) {
  document.getElementById('import-progress').style.display = 'block';
  document.getElementById('import-prog-fill').style.width = pct + '%';
  document.getElementById('import-prog-label').textContent = label;
}

function showImportError(msg) {
  const el = document.getElementById('import-error');
  el.textContent = '⚠ ' + msg;
  el.style.display = 'block';
  document.getElementById('import-progress').style.display = 'none';
}

const autoDetectFileType = (filename) => {
  const lowerName = filename.toLowerCase();
  if (lowerName.includes('payment') || lowerName.includes('revenue') || lowerName.includes('doanh')) return 'payment';
  if (lowerName.includes('event') || lowerName.includes('funnel') || lowerName.includes('tracking')) return 'events';
  return null;
};

async function importMultipleFilesFromTab() {
  const files = Array.from(document.getElementById('import-multi-input').files);
  if (files.length === 0) return showImportError('Vui lòng chọn ít nhất một file CSV.');

  const unknownFiles = files.filter(f => !autoDetectFileType(f.name));
  if (unknownFiles.length > 0) return showImportError(`Không xác định được loại file: ${unknownFiles.map(f => f.name).join(', ')}`);

  document.getElementById('import-error').style.display = 'none';
  setImportProgress(10, `Đang gửi ${files.length} file lên server...`);

  try {
    let successCount = 0;
    for (let i = 0; i < files.length; i++) {
      const file = files[i], type = autoDetectFileType(file.name);
      setImportProgress(30 + (i / files.length) * 40, `Đang parse ${file.name}...`);
      const form = new FormData();
      form.append(type, file);
      const res = await fetch('/api/import', {method: 'POST', body: form});
      const json = await res.json();
      if (!res.ok || json.status === 'error') throw new Error(json.message);
      successCount++;
    }
    
    setImportProgress(90, 'Đang tải data mới nhất...');
    const latestRes = await fetch('/api/import/latest');
    const latestJson = await latestRes.json();
    
    if (latestRes.ok && latestJson.status === 'success') {
      applyDashboardPayload(latestJson.payment, latestJson.events);
      if (latestJson.payment) { APP.revenue = latestJson.payment.revenue; APP.behavior = latestJson.payment.behavior; if (APP.revenue) renderRevenue(); if (APP.behavior) renderBehavior(); }
      if (latestJson.events) { APP.funnel = latestJson.events.funnel || latestJson.events; if (APP.funnel) renderFunnel(); }
      updateStatusBar(); renderReport(); loadForecast();
    }
    
    setImportProgress(100, 'Hoàn thành!');
    setTimeout(() => {
      loadImportedList();
      document.getElementById('import-progress').style.display = 'none';
      document.getElementById('import-multi-input').value = '';
      updateImportFileLabel();
      const s = document.createElement('div');
      s.style.cssText = 'position:fixed;top:20px;right:20px;background:var(--teal-l);color:var(--teal-d);padding:16px 20px;border-radius:var(--r-lg);border:1px solid var(--teal)';
      s.innerHTML = `<strong>✅ Import thành công!</strong><br>${successCount} file(s)`;
      document.body.appendChild(s);
      setTimeout(() => s.remove(), 5000);
      switchTab('revenue');
    }, 600);
  } catch(e) { showImportError(e.message); }
}

const TEAL_STOPS = ['#e1f5ee','#9fe1cb','#5dcaa5','#1d9e75','#0f6e56','#085041','#04342c'];
const C_PLAT = {Android:'#1d9e75',iOS:'#378add'};
const C_NET = {Wifi:'#7f77dd','4G':'#1d9e75','5G':'#ef9f27','3G':'#e24b4a'};
const C_SEG = {VIP:'#7f77dd',Regular:'#1d9e75',New:'#378add',Member:'#ef9f27'};
const RFM_COLORS = {'VIP/Champion':{bg:'#eeedfe',c:'#534ab7'},'Trung thành':{bg:'#e6f1fb',c:'#185fa5'},'Tiềm năng':{bg:'#e1f5ee',c:'#0f6e56'},'Mới':{bg:'#faeeda',c:'#854f0b'},'At-risk':{bg:'#fcebeb',c:'#a32d2d'}};

