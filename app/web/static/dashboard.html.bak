<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clawsome Agent Analytics</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f4f4f2;--surface:#fff;--surface2:#f9f9f7;
  --border:rgba(0,0,0,.07);--border-md:rgba(0,0,0,.13);
  --t1:#181816;--t2:#52524e;--t3:#98968e;
  --teal:#1d9e75;--teal-l:#e1f5ee;--teal-m:#5dcaa5;--teal-d:#0f6e56;--teal-8:#085041;
  --red:#e24b4a;--red-l:#fcebeb;--red-d:#a32d2d;
  --amber:#ef9f27;--amber-l:#faeeda;--amber-d:#854f0b;
  --purple:#7f77dd;--purple-l:#eeedfe;--purple-d:#534ab7;
  --blue:#378add;--blue-l:#e6f1fb;--blue-d:#185fa5;
  --nav-w:220px;
  --r:8px;--r-lg:12px;
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--t1);font-size:14px;display:flex;min-height:100vh}

/* ── SIDEBAR NAV ── */
.sidebar{width:var(--nav-w);min-height:100vh;background:var(--surface);border-right:.5px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;z-index:200}
.sidebar-brand{padding:20px 20px 16px;border-bottom:.5px solid var(--border)}
.brand-logo{font-size:13px;font-weight:700;color:var(--teal-d);letter-spacing:-.01em}
.brand-sub{font-size:11px;color:var(--t3);margin-top:2px}
.nav-section{padding:12px 12px 4px;font-size:10px;font-weight:600;color:var(--t3);letter-spacing:.08em;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 12px;margin:1px 8px;border-radius:var(--r);cursor:pointer;color:var(--t2);font-size:13px;font-weight:500;transition:background .12s,color .12s;position:relative}
.nav-item:hover{background:var(--surface2);color:var(--t1)}
.nav-item.active{background:var(--teal-l);color:var(--teal-d)}
.nav-item.active .nav-icon{color:var(--teal)}
.nav-icon{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.nav-dot{width:6px;height:6px;border-radius:50%;background:var(--teal);position:absolute;right:10px;top:50%;transform:translateY(-50%)}
.sidebar-bottom{margin-top:auto;padding:16px}
.data-status{background:var(--surface2);border:.5px solid var(--border);border-radius:var(--r);padding:10px 12px}
.data-status-title{font-size:11px;font-weight:600;color:var(--t2);margin-bottom:6px;display:flex;align-items:center;gap:6px}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--t3)}
.status-dot.active{background:var(--teal)}
.data-file{font-size:11px;color:var(--t3);margin-bottom:3px}
.data-file span{color:var(--t2);font-weight:500}

/* ── MAIN ── */
.main{margin-left:var(--nav-w);flex:1;min-height:100vh;display:flex;flex-direction:column}
.topbar{background:var(--surface);border-bottom:.5px solid var(--border);padding:0 24px;height:52px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:100}
.topbar-title{font-size:15px;font-weight:600;color:var(--t1)}
.topbar-sub{font-size:12px;color:var(--t3);margin-left:4px}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:8px}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;border:.5px solid var(--border-md);background:transparent;border-radius:var(--r);padding:6px 12px;font-size:12px;color:var(--t2);cursor:pointer;transition:background .12s;white-space:nowrap;font-family:inherit}
.btn:hover{background:var(--bg)}
.btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.btn-teal{background:var(--teal);color:#fff;border-color:var(--teal)}
.btn-teal:hover{background:var(--teal-d)}

/* ── PAGE CONTENT ── */
.page{display:none;padding:24px;animation:fadeIn .18s ease}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* ── METRIC CARDS ── */
.metric-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px}
.metric-card{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r-lg);padding:16px 18px}
.mc-label{font-size:11px;font-weight:500;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}
.mc-value{font-size:24px;font-weight:700;letter-spacing:-.03em;line-height:1;margin-bottom:5px}
.mc-delta{font-size:11px;display:flex;align-items:center;gap:3px}
.delta-up{color:var(--teal-d)}
.delta-down{color:var(--red-d)}
.delta-flat{color:var(--t3)}
.badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;font-weight:600;padding:2px 7px;border-radius:99px}
.b-teal{background:var(--teal-l);color:var(--teal-d)}
.b-red{background:var(--red-l);color:var(--red-d)}
.b-amber{background:var(--amber-l);color:var(--amber-d)}
.b-purple{background:var(--purple-l);color:var(--purple-d)}
.b-blue{background:var(--blue-l);color:var(--blue-d)}

/* ── SECTION ── */
.sec-hd{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.sec-hd h2{font-size:13px;font-weight:600;white-space:nowrap}
.sec-hd .sub{font-size:12px;color:var(--t3)}
.sec-line{flex:1;height:.5px;background:var(--border)}

/* ── CARDS ── */
.card{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r-lg);padding:18px 20px}
.card-title{font-size:13px;font-weight:600;margin-bottom:3px}
.card-sub{font-size:11px;color:var(--t3);margin-bottom:14px}
.two-col{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:22px}
.two-col-eq{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:22px}
.chart-wrap{position:relative;height:200px}
.chart-wrap-sm{position:relative;height:160px}

/* ── TABLE ── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
thead tr{background:var(--surface2);border-bottom:.5px solid var(--border)}
th{padding:9px 12px;font-size:11px;font-weight:500;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;text-align:left;white-space:nowrap}
th.r{text-align:right}
tbody tr{border-bottom:.5px solid var(--border);cursor:pointer;transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--surface2)}
tbody tr.sel{background:var(--teal-l)}
td{padding:10px 12px;font-size:13px;vertical-align:middle}
td.r{text-align:right}
.sn{font-weight:500}
.si{font-size:11px;color:var(--t3)}

/* FUNNEL SPECIFICS */
.step-n{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;font-size:10px;font-weight:700;background:var(--bg);color:var(--t2);border:.5px solid var(--border-md);margin-right:8px;flex-shrink:0}
.step-n.worst{background:var(--red);color:#fff;border-color:var(--red)}
.bar-tr{background:var(--bg);border-radius:3px;height:18px;overflow:hidden;min-width:100px}
.bar-fi{height:100%;border-radius:3px;display:flex;align-items:center;padding-left:7px;font-size:10px;font-weight:600;color:var(--teal-8);transition:width .6s cubic-bezier(.4,0,.2,1)}
.cpill{font-size:11px;font-weight:600;padding:2px 7px;border-radius:99px}
.cg{background:var(--teal-l);color:var(--teal-d)}
.cw{background:var(--amber-l);color:var(--amber-d)}
.cb{background:var(--red-l);color:var(--red-d)}
.drp{font-size:11px;color:var(--t3)}
.drp.bad{color:var(--red-d);font-weight:600}

/* HEATMAP */
.heatmap-grid{display:grid;grid-template-columns:36px repeat(7,1fr);gap:3px;margin-top:4px}
.hm-cell{height:26px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500}
.hm-lbl{color:var(--t3);justify-content:flex-end;padding-right:4px;font-size:10px;background:none}
.hm-hdr{background:none;color:var(--t3);font-size:10px;font-weight:500}

/* RFM TABLE */
.rfm-badge{display:inline-flex;font-size:10px;padding:2px 8px;border-radius:99px;font-weight:600}
.rfm-action{font-size:11px;color:var(--t3)}

/* INSIGHT CARDS */
.insight{border-radius:var(--r);padding:12px 14px;margin-bottom:10px;display:flex;gap:12px;border:.5px solid var(--border)}
.insight-left{width:3px;border-radius:2px;flex-shrink:0;align-self:stretch}
.insight-body{flex:1}
.insight-title{font-size:13px;font-weight:600;margin-bottom:4px;display:flex;align-items:center;gap:8px}
.insight-text{font-size:12px;color:var(--t2);line-height:1.6}
.p0{background:var(--red-l)}.p0 .insight-left{background:var(--red)}
.p1{background:var(--amber-l)}.p1 .insight-left{background:var(--amber)}
.p2{background:var(--blue-l)}.p2 .insight-left{background:var(--blue)}

/* CHAT */
.chat-container{display:flex;flex-direction:column;height:calc(100vh - 52px - 48px);max-height:700px}
.chat-msgs{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:14px}
.msg{display:flex;gap:10px;align-items:flex-start}
.msg-user{flex-direction:row-reverse}
.msg-av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.av-ai{background:var(--teal-l);color:var(--teal-d)}
.av-user{background:var(--purple-l);color:var(--purple-d)}
.msg-bubble{max-width:72%;padding:10px 14px;border-radius:var(--r-lg);font-size:13px;line-height:1.6}
.bubble-ai{background:var(--surface);border:.5px solid var(--border)}
.bubble-user{background:var(--teal);color:#fff}
.msg-time{font-size:10px;color:var(--t3);margin-top:4px}
.chat-bottom{padding:14px 20px;border-top:.5px solid var(--border);background:var(--surface)}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
.chip{font-size:11px;padding:4px 10px;border:.5px solid var(--border-md);border-radius:99px;color:var(--t2);cursor:pointer;background:var(--surface);transition:background .12s}
.chip:hover{background:var(--bg);border-color:var(--teal);color:var(--teal-d)}
.chat-input-row{display:flex;gap:8px;align-items:center}
.chat-input-row input{flex:1;padding:8px 12px;border:.5px solid var(--border-md);border-radius:var(--r);font-size:13px;font-family:inherit;background:var(--bg);color:var(--t1)}
.chat-input-row input:focus{outline:none;border-color:var(--teal)}
.thinking{display:flex;gap:4px;align-items:center;padding:4px 0}
.thinking span{width:6px;height:6px;border-radius:50%;background:var(--t3);animation:bounce .9s infinite}
.thinking span:nth-child(2){animation-delay:.15s}
.thinking span:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

/* REPORT PAGE */
.report-hd{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r-lg);padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between}
.report-body{background:var(--surface);border:.5px solid var(--border);border-radius:var(--r-lg);padding:20px 24px}
.report-section{margin-bottom:20px}
.report-section h3{font-size:13px;font-weight:600;margin-bottom:10px;color:var(--t2);text-transform:uppercase;letter-spacing:.05em}
.report-kv{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;margin-bottom:16px}
.kv-item{background:var(--surface2);border-radius:var(--r);padding:10px 12px}
.kv-label{font-size:10px;color:var(--t3);margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em}
.kv-val{font-size:18px;font-weight:700;letter-spacing:-.02em}

/* UPLOAD OVERLAY */
.upload-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:none;align-items:center;justify-content:center}
.upload-overlay.open{display:flex}
.upload-modal{background:var(--surface);border-radius:var(--r-lg);padding:32px;width:440px;max-width:90vw;position:relative}
.modal-close{position:absolute;top:12px;right:12px;background:none;border:none;cursor:pointer;color:var(--t3);padding:4px}
.modal-close:hover{color:var(--t1)}
.modal-close svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round}
.modal-title{font-size:16px;font-weight:700;margin-bottom:6px}
.modal-sub{font-size:13px;color:var(--t2);margin-bottom:20px;line-height:1.5}
.drop-zone{border:1.5px dashed var(--border-md);border-radius:var(--r-lg);padding:32px 24px;text-align:center;cursor:pointer;transition:border-color .15s,background .15s;margin-bottom:14px}
.drop-zone:hover,.drop-zone.over{border-color:var(--teal);background:var(--teal-l)}
.drop-icon{width:36px;height:36px;margin:0 auto 10px;background:var(--teal-l);border-radius:8px;display:flex;align-items:center;justify-content:center}
.drop-icon svg{width:18px;height:18px;stroke:var(--teal-d);fill:none;stroke-width:2;stroke-linecap:round}
.drop-title{font-size:14px;font-weight:600;margin-bottom:4px}
.drop-sub{font-size:12px;color:var(--t3)}
.csv-types{display:flex;gap:8px;margin-bottom:16px}
.csv-type-btn{flex:1;padding:10px;border:.5px solid var(--border-md);border-radius:var(--r);cursor:pointer;text-align:center;transition:border-color .12s,background .12s;background:var(--surface)}
.csv-type-btn:hover{border-color:var(--teal);background:var(--teal-l)}
.csv-type-btn.active-type{border-color:var(--teal);background:var(--teal-l)}
.csv-type-btn .ct-label{font-size:12px;font-weight:600;color:var(--t1);margin-bottom:2px}
.csv-type-btn .ct-desc{font-size:10px;color:var(--t3)}
.upload-progress{display:none;margin-top:12px}
.prog-bar-wrap{height:4px;background:var(--teal-l);border-radius:2px;overflow:hidden;margin-bottom:6px}
.prog-bar-fill{height:100%;background:var(--teal);border-radius:2px;transition:width .3s}
.prog-label{font-size:12px;color:var(--t2);text-align:center}
.upload-error{font-size:12px;color:var(--red-d);background:var(--red-l);border:.5px solid var(--red);border-radius:var(--r);padding:8px 10px;margin-top:8px;display:none}

/* FLOATING BUTTON */
.fab{position:fixed;bottom:28px;right:28px;z-index:300;background:var(--teal);color:#fff;border:none;border-radius:99px;padding:11px 18px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(29,158,117,.35);transition:background .15s,box-shadow .15s;font-family:inherit}
.fab:hover{background:var(--teal-d);box-shadow:0 6px 20px rgba(29,158,117,.45)}
.fab svg{width:16px;height:16px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.fab-pulse{width:8px;height:8px;border-radius:50%;background:#fff;opacity:.7;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.3)}}

/* EMPTY STATE */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;text-align:center;gap:12px}
.empty-icon{width:48px;height:48px;background:var(--surface2);border-radius:12px;display:flex;align-items:center;justify-content:center}
.empty-icon svg{width:24px;height:24px;stroke:var(--t3);fill:none;stroke-width:1.5;stroke-linecap:round}
.empty-title{font-size:15px;font-weight:600;color:var(--t2)}
.empty-sub{font-size:13px;color:var(--t3);max-width:320px;line-height:1.5}

#file-input{display:none}
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">Clawsome Agent</div>
    <div class="brand-sub">Analytics Dashboard</div>
  </div>

  <div class="nav-section">Phân tích</div>
  <div class="nav-item active" onclick="switchTab('revenue',this)">
    <svg class="nav-icon" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    Doanh thu
  </div>
  <div class="nav-item" onclick="switchTab('behavior',this)">
    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    Hành vi
  </div>
  <div class="nav-item" onclick="switchTab('funnel',this)">
    <svg class="nav-icon" viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    Funnel
  </div>

  <div class="nav-section" style="margin-top:8px">Báo cáo & Dự báo</div>
  <div class="nav-item" onclick="switchTab('report',this)">
    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
    Báo cáo
  </div>
  <div class="nav-item" onclick="switchTab('forecast',this)">
    <svg class="nav-icon" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    Dự báo AI
    <div class="nav-dot"></div>
  </div>

  <div class="nav-section" style="margin-top:8px">Quản lý</div>
  <div class="nav-item" onclick="switchTab('import',this)">
    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    Import CSV
  </div>

  <div class="sidebar-bottom">
    <div class="data-status">
      <div class="data-status-title">
        <div class="status-dot" id="status-dot"></div>
        Nguồn dữ liệu
      </div>
      <div class="data-file" id="status-payment">Payment: <span>Chưa có</span></div>
      <div class="data-file" id="status-events">Events: <span>Chưa có</span></div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div>
      <span class="topbar-title" id="topbar-title">Doanh thu</span>
      <span class="topbar-sub" id="topbar-sub"></span>
    </div>
    <div class="topbar-right">
      <button class="btn" onclick="loadDemo()">Demo data</button>
    </div>
  </div>

  <!-- REVENUE TAB -->
  <div class="page active" id="page-revenue">
    <div id="rev-empty" class="empty-state">
      <div class="empty-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
      <div class="empty-title">Chưa có dữ liệu doanh thu</div>
      <div class="empty-sub">Import file CSV từ tab "Import CSV" ở cuối sidebar để bắt đầu phân tích.</div>
    </div>
    <div id="rev-content" style="display:none">
      <div class="metric-row" id="rev-metrics"></div>
      <div class="two-col" style="margin-bottom:16px">
        <div class="card">
          <div class="card-title">Doanh thu theo ngày trong tuần</div>
          <div class="card-sub">Tổng hợp — màu đậm = cuối tuần</div>
          <div class="chart-wrap"><canvas id="rev-bar-chart"></canvas></div>
        </div>
        <div class="card">
          <div class="card-title">Cơ cấu loại vé</div>
          <div class="card-sub">% doanh thu</div>
          <div class="chart-wrap"><canvas id="rev-pie-chart"></canvas></div>
        </div>
      </div>
      <div class="two-col" style="margin-bottom:0">
        <div class="card">
          <div class="card-title">Top 5 phim theo doanh thu</div>
          <div class="card-sub">Kỳ hiện tại</div>
          <div id="top-movies-list"></div>
        </div>
        <div class="card">
          <div class="card-title">Phương thức thanh toán</div>
          <div class="card-sub">% doanh thu theo method</div>
          <div class="chart-wrap-sm"><canvas id="pay-chart"></canvas></div>
        </div>
      </div>
    </div>
  </div>

  <!-- BEHAVIOR TAB -->
  <div class="page" id="page-behavior">
    <div id="beh-empty" class="empty-state">
